{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/chats/[conversationId]",
      "regex": "^/chats/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPconversationId": "nxtPconversationId"
      },
      "namedRegex": "^/chats/(?<nxtPconversationId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/groups/[groupId]",
      "regex": "^/groups/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgroupId": "nxtPgroupId"
      },
      "namedRegex": "^/groups/(?<nxtPgroupId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/users/[userId]",
      "regex": "^/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/users/(?<nxtPuserId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/audit-logs",
      "regex": "^/admin/audit\\-logs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/audit\\-logs(?:/)?$"
    },
    {
      "page": "/admin/events",
      "regex": "^/admin/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/events(?:/)?$"
    },
    {
      "page": "/admin/operators",
      "regex": "^/admin/operators(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/operators(?:/)?$"
    },
    {
      "page": "/admin/reports",
      "regex": "^/admin/reports(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/reports(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/users(?:/)?$"
    },
    {
      "page": "/admin/verifications",
      "regex": "^/admin/verifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/verifications(?:/)?$"
    },
    {
      "page": "/chats",
      "regex": "^/chats(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/chats(?:/)?$"
    },
    {
      "page": "/groups",
      "regex": "^/groups(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/groups(?:/)?$"
    },
    {
      "page": "/home",
      "regex": "^/home(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/home(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/me",
      "regex": "^/me(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/me(?:/)?$"
    },
    {
      "page": "/notifications",
      "regex": "^/notifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/notifications(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}